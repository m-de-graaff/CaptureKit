root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{cpp,hpp,c,h,cc,hh}]
indent_style = space
indent_size = 4
max_line_length = 120

[*.{cmake,CMakeLists.txt}]
indent_style = space
indent_size = 2

[*.{json,yml,yaml}]
indent_style = space
indent_size = 2

[*.{md,txt}]
indent_style = space
indent_size = 2
max_line_length = 80

[*.{sh,bat,ps1}]
indent_style = space
indent_size = 2
